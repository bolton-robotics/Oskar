<launch>

<let name="urdf_path" value="$(find-pkg-share oskar_bringup)/Description/ros2con.robot.urdf.xacro" />

<let name="rviz_config_path" value="$(find-pkg-share oskar_bringup)/rviz/oskar.rviz" />

<node pkg="robot_state_publisher" exec="robot_state_publisher">
  <param name="robot_description" value="$(command 'xacro $(var urdf_path)')" />
</node>

<node pkg="controller_manager" exec="ros2_control_node">
  <param from="$(find-pkg-share oskar_bringup)/config/robot_controllers.yaml" />
</node>

<node pkg="controller_manager" exec="spawner" args="joint_broad" />

<node pkg="controller_manager" exec="spawner" args="diff_cont" />

<node pkg="rviz2" exec="rviz2" output="screen" args="-d $(var rviz_config_path)" />

</launch>